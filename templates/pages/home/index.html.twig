{% extends 'base.html.twig' %}

{% block title %}Tableau de bord
{% endblock %}

{% block body %}
	<div
		class="container-fluid px-4 py-4">

		<div class="mb-4">
			<h1 class="fw-bold mb-1">Tableau de bord</h1>
			<p class="text-muted mb-0">Bonjour
				{{ app.user.firstName }}
				!</p>
		</div>

		<div class="row g-3 mb-4">
			<div class="col-sm-6 col-xl-4">
				<div class="card border-0 shadow-sm h-100">
					<div class="card-body d-flex align-items-center gap-3">
						<div class="rounded-3 bg-primary bg-opacity-10 p-3 d-flex align-items-center justify-content-center" style="width:56px;height:56px;">
							<i class="bi bi-box-seam fs-4 text-primary"></i>
						</div>
						<div>
							<div class="fs-2 fw-bold lh-1">{{ productCount }}</div>
							<div class="text-muted small mt-1">Produits</div>
						</div>
						<a href="{{ path('product.list') }}" class="stretched-link"></a>
					</div>
				</div>
			</div>

			{% if is_granted('CUSTOMER_VIEW') %}
				<div class="col-sm-6 col-xl-4">
					<div class="card border-0 shadow-sm h-100">
						<div class="card-body d-flex align-items-center gap-3">
							<div class="rounded-3 bg-success bg-opacity-10 p-3 d-flex align-items-center justify-content-center" style="width:56px;height:56px;">
								<i class="bi bi-person-lines-fill fs-4 text-success"></i>
							</div>
							<div>
								<div class="fs-2 fw-bold lh-1">{{ customerCount }}</div>
								<div class="text-muted small mt-1">Clients</div>
							</div>
							<a href="{{ path('customer.list') }}" class="stretched-link"></a>
						</div>
					</div>
				</div>
			{% endif %}

			{% if is_granted('ADMIN_VIEW') %}
				<div class="col-sm-6 col-xl-4">
					<div class="card border-0 shadow-sm h-100">
						<div class="card-body d-flex align-items-center gap-3">
							<div class="rounded-3 bg-warning bg-opacity-10 p-3 d-flex align-items-center justify-content-center" style="width:56px;height:56px;">
								<i class="bi bi-people fs-4 text-warning"></i>
							</div>
							<div>
								<div class="fs-2 fw-bold lh-1">{{ userCount }}</div>
								<div class="text-muted small mt-1">Utilisateurs</div>
							</div>
							<a href="{{ path('user.list') }}" class="stretched-link"></a>
						</div>
					</div>
				</div>
			{% endif %}
		</div>

		<div
			class="row g-3 mb-4">

			{% if is_granted('CUSTOMER_VIEW') %}
				<div class="col-xl-6">
					<div class="card border-0 shadow-sm h-100">
						<div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
							<span class="fw-semibold">Clients récents</span>
							<a href="{{ path('customer.list') }}" class="btn btn-sm btn-outline-primary">Voir tout</a>
						</div>
						<div class="card-body p-0">
							<table class="table table-hover align-middle mb-0">
								<thead class="table-light">
									<tr>
										<th class="ps-3">Nom</th>
										<th>Email</th>
										<th class="pe-3">Inscrit le</th>
									</tr>
								</thead>
								<tbody>
									{% for customer in recentCustomers %}
										<tr>
											<td class="ps-3 fw-medium">{{ customer.firstName }}
												{{ customer.lastName }}</td>
											<td class="text-muted small">{{ customer.email }}</td>
											<td class="pe-3 text-muted small">{{ customer.createdAt|date('d/m/Y') }}</td>
										</tr>
									{% else %}
										<tr>
											<td colspan="3" class="text-center text-muted py-4">Aucun client</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			{% endif %}

			<div class="col-xl-{% if is_granted('CUSTOMER_VIEW') %}6{% else %}12{% endif %}">
				<div class="card border-0 shadow-sm h-100">
					<div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
						<span class="fw-semibold">Derniers produits</span>
						<a href="{{ path('product.list') }}" class="btn btn-sm btn-outline-primary">Voir tout</a>
					</div>
					<div class="card-body p-0">
						<table class="table table-hover align-middle mb-0">
							<thead class="table-light">
								<tr>
									<th class="ps-3">Nom</th>
									<th>Type</th>
									<th class="pe-3 text-end">Prix</th>
								</tr>
							</thead>
							<tbody>
								{% for product in recentProducts %}
									<tr>
										<td class="ps-3 fw-medium">{{ product.name }}</td>
										<td>
											<span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle">{{ product.type }}</span>
										</td>
										<td class="pe-3 text-end fw-semibold">{{ product.price|number_format(2, ',', ' ') }}
											&euro;</td>
									</tr>
								{% else %}
									<tr>
										<td colspan="3" class="text-center text-muted py-4">Aucun produit</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
